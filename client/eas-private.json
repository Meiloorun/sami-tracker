{
  "cli": {
    "version": ">= 18.3.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_LOCAL_URL": "LOCALURL",
        "EXPO_PUBLIC_API_BASE_URL": "BASEURL",
        "EXPO_PUBLIC_API_LOCAL_HEALTH_TIMEOUT_MS": "2500",
        "EXPO_PUBLIC_API_DEBUG": "true"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_LOCAL_URL": "LOCALURL",
        "EXPO_PUBLIC_API_BASE_URL": "BASEURL",
        "EXPO_PUBLIC_API_LOCAL_HEALTH_TIMEOUT_MS": "2500",
        "EXPO_PUBLIC_API_DEBUG": "true"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "apk"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
